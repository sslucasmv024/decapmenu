---
// Recibimos todo el objeto 'promo' desestructurado y la URL base
const { 
  titulo, 
  descripcion, 
  precio_promo, // Nombre exacto en Directus
  imagen_promo, // Nombre exacto en Directus
  dias_promos,   // Nombre exacto en Directus
  urlBase 
} = Astro.props;

const formatter = new Intl.NumberFormat('es-AR');

// La lógica de la imagen la hacés adentro del componente para no ensuciar el index
const urlImagen = imagen_promo 
  ? `${urlBase}/assets/${imagen_promo}?width=200&height=200&fit=cover` 
  : null;

const procesarNegritas = (texto) => {
  if (!texto) return "";
  return texto.replace(/\*\*(.*?)\*\*/g, '<b class="text-white font-black tracking-tight">$1</b>');
};
---

<div class="bg-gradient-to-br from-slate-800 to-slate-900 rounded-[2rem] p-6 border border-slate-700/50 relative overflow-hidden shadow-2xl flex flex-col gap-5">
    <div class="relative z-10 w-full">
        <h3 class="text-xl font-black text-white uppercase leading-tight tracking-tight">
            {titulo}
        </h3>
    </div>

    <div class="relative z-10 flex gap-4 items-center w-full justify-between">
        <div class="flex items-center gap-4 flex-1 min-w-0">
            {urlImagen && (
                <img src={urlImagen} class="w-16 h-16 md:w-20 md:h-20 object-cover rounded-2xl shadow-lg border border-white/10 flex-shrink-0" alt={titulo} />
            )}
            <div class="min-w-0">
                <p class="text-slate-400 text-[14px] leading-relaxed line-clamp-none" set:html={procesarNegritas(descripcion)} />
            </div>
        </div>

        <div class="text-right pl-4 flex flex-col justify-center min-w-[110px] flex-shrink-0 border-l border-slate-700/30">
            <span class="text-2xl font-black text-amber-500">
                ${formatter.format(precio_promo || 0)}
            </span>
            {dias_promos && (
                <span class="text-[10px] font-black uppercase text-green-500 mt-1 italic leading-none tracking-tighter">
                    {dias_promos}
                </span>
            )}
        </div>
    </div>
</div>